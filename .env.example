# ── Shopify Storefront API ────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Without these, the site runs in DEMO MODE with a built-in catalog.

# Your store's myshopify domain (no protocol), e.g. chikigo.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API token. Shopify shows TWO on the API credentials page —
# Admin → Apps and sales channels → Develop apps → your app → API credentials
# → Storefront API:
#
#   • Public access token  (plain hex, e.g. f5705cb4…) — for client-side use
#   • Private access token (starts with "shpat_")      — for server-side use
#
# This app calls Shopify only from the server, so the PRIVATE token is
# recommended (higher rate limits). Paste it below — the app auto-detects the
# "shpat_" prefix and sends the correct `Shopify-Storefront-Private-Token`
# header. A public hex token also works here and uses the public header.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: set the private token here explicitly instead of above. If both are
# set, this one wins. (Same value as the "Private access token" in Shopify.)
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# Optional. Storefront API version (default used if unset).
SHOPIFY_API_VERSION=2025-10

# ── Site ──────────────────────────────────────────────────────────────────
# WhatsApp number for order support, digits only with country code.
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Public site URL (used for metadata/OG tags)
NEXT_PUBLIC_SITE_URL=https://chikigo.example.com
