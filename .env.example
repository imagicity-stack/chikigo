# ── Shopify Storefront API ────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Without these, the site runs in DEMO MODE with a built-in catalog.

# Your store's myshopify domain (no protocol), e.g. chikigo.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API access token.
# Shopify Admin → Settings → Apps and sales channels → Develop apps →
# Create app → Configure Storefront API scopes (unauthenticated_read_product_listings,
# unauthenticated_write_checkouts, unauthenticated_read_checkouts) → Install →
# API credentials → Storefront API access token.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional. Storefront API version (default used if unset).
SHOPIFY_API_VERSION=2025-10

# ── Site ──────────────────────────────────────────────────────────────────
# WhatsApp number for order support, digits only with country code.
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999

# Public site URL (used for metadata/OG tags)
NEXT_PUBLIC_SITE_URL=https://chikigo.example.com
